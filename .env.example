# RunningHub API Configuration
RUNNINGHUB_API_KEY=xxx
RUNNINGHUB_BASE_URL=https://www.runninghub.cn
RUNNINGHUB_WORKFLOW_ID=xxx
# Server Configuration
PORT=4111

# Image Generation Defaults
DEFAULT_IMAGE_SIZE=1024x1024
DEFAULT_STEPS=20
DEFAULT_CFG_SCALE=2.5
DEFAULT_BATCH_SIZE=1

# Optional: Webhook URL for task completion notifications
WEBHOOK_URL=

# Optional: Instance type (e.g., "plus" for 48G GPU)
INSTANCE_TYPE=

# Optional: Retain seconds (10-180) for enterprise shared API keys
RETAIN_SECONDS=60
